# GitHub personal access token (classic) with public_repo scope
# Used to create issues when users submit bug reports
GITHUB_TOKEN=your_github_token_here

# Cloudflare Turnstile keys for spam protection on the bug report form
# Get these from https://dash.cloudflare.com/ -> Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA_your_site_key_here
TURNSTILE_SECRET_KEY=0x3AAAA_your_secret_key_here
